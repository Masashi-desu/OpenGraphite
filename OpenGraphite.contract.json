{
  "version": "0.1.0",
  "types": [
    "page",
    "frame",
    "text",
    "button",
    "image"
  ],
  "layouts": [
    "vertical",
    "horizontal",
    "absolute"
  ],
  "roles": [
    "page-preview",
    "landing-hero",
    "primary-button",
    "secondary-button",
    "card",
    "eyebrow",
    "muted"
  ],
  "editableAttributes": [
    "data-og-type",
    "data-og-layout",
    "data-og-role",
    "data-og-component",
    "data-og-component-kind",
    "data-og-variant",
    "data-og-slot",
    "data-og-part",
    "data-og-text-source",
    "data-og-lang-source",
    "data-og-lang-field",
    "data-og-dir-source",
    "data-og-dir-field",
    "data-i18n-key",
    "data-og-text-variant-eng",
    "data-og-hidden",
    "data-og-locked"
  ],
  "runtimeAttributes": [
    "data-og-selected",
    "data-og-editing",
    "data-og-expanded",
    "data-og-generated",
    "data-og-component-error",
    "data-og-host-id",
    "data-og-instance-source",
    "data-og-source-component",
    "data-og-source-instance",
    "data-og-slot-origin",
    "data-og-preview-locale",
    "data-og-preview-dir",
    "data-og-runtime-fallback-html",
    "contenteditable",
    "spellcheck"
  ],
  "cssVariables": [
    { "name": "--og-page-background", "category": "theme", "syntax": "<color>", "editable": true },
    { "name": "--og-text-color", "category": "theme", "syntax": "<color>", "editable": true },
    { "name": "--og-muted-color", "category": "theme", "syntax": "<color>", "editable": true },
    { "name": "--og-accent", "category": "theme", "syntax": "<color>", "editable": true },
    { "name": "--og-accent-foreground", "category": "theme", "syntax": "<color>", "editable": true },
    { "name": "--og-width", "category": "box", "syntax": "<length-percentage>|auto|min()|max()|clamp()", "editable": true },
    { "name": "--og-height", "category": "box", "syntax": "<length-percentage>|auto|min()|max()|clamp()", "editable": true },
    { "name": "--og-min-width", "category": "box", "syntax": "<length-percentage>|auto|min()|max()|clamp()", "editable": true },
    { "name": "--og-min-height", "category": "box", "syntax": "<length-percentage>|auto|min()|max()|clamp()", "editable": true },
    { "name": "--og-max-width", "category": "box", "syntax": "<length-percentage>|none|min()|max()|clamp()", "editable": true },
    { "name": "--og-flex", "category": "layout", "syntax": "<flex-shorthand>", "editable": true },
    { "name": "--og-margin", "category": "layout", "syntax": "<box-shorthand>", "editable": true },
    { "name": "--og-padding", "category": "layout", "syntax": "<box-shorthand>", "editable": true },
    { "name": "--og-gap", "category": "layout", "syntax": "<length-percentage>{1,2}", "editable": true },
    { "name": "--og-align", "category": "layout", "syntax": "<align-items>", "editable": true },
    { "name": "--og-justify", "category": "layout", "syntax": "<justify-content>", "editable": true },
    { "name": "--og-x", "category": "position", "syntax": "<length-percentage>", "editable": true },
    { "name": "--og-y", "category": "position", "syntax": "<length-percentage>", "editable": true },
    { "name": "--og-foreground", "category": "appearance", "syntax": "<color>", "editable": true },
    { "name": "--og-background", "category": "appearance", "syntax": "<color>|<image>|linear-gradient()", "editable": true },
    { "name": "--og-border", "category": "appearance", "syntax": "<border-shorthand>", "editable": true },
    { "name": "--og-radius", "category": "appearance", "syntax": "<box-shorthand>", "editable": true },
    { "name": "--og-shadow", "category": "appearance", "syntax": "<box-shadow>", "editable": true },
    { "name": "--og-font-size", "category": "text", "syntax": "<length-percentage>", "editable": true },
    { "name": "--og-font-weight", "category": "text", "syntax": "<number>|<font-weight-keyword>", "editable": true },
    { "name": "--og-line-height", "category": "text", "syntax": "<number>|<length-percentage>", "editable": true },
    { "name": "--og-letter-spacing", "category": "text", "syntax": "<length>|normal", "editable": true },
    { "name": "--og-text-align", "category": "text", "syntax": "<text-align>", "editable": true },
    { "name": "--og-object-fit", "category": "media", "syntax": "<object-fit>", "editable": true },
    { "name": "--og-scale-x", "category": "transform", "syntax": "<number>", "editable": true },
    { "name": "--og-scale-y", "category": "transform", "syntax": "<number>", "editable": true },
    { "name": "--og-transform-origin", "category": "transform", "syntax": "<position>", "editable": true },
    { "name": "--og-edit-width", "category": "runtime", "syntax": "<length-percentage>|auto", "editable": false },
    { "name": "--og-edit-min-height", "category": "runtime", "syntax": "<length-percentage>", "editable": false }
  ]
}

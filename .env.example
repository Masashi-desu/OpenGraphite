# OpenGraphite の DMG 作成 / 公証を一発実行するための設定例です。
# 実運用ではこのファイルを .env としてコピーし、各値を自分の環境へ合わせてください。

# Release ビルド設定
RELEASE_SCHEME="OpenGraphite"
RELEASE_CONFIGURATION="Release"
RELEASE_DESTINATION="platform=macOS"
RELEASE_DERIVED_DATA_PATH="build/ReleaseDerivedData"
RELEASE_OUTPUT_DIR="dist"

# 既存の .app を使う場合だけ指定します。
# APP_PATH="build/ReleaseDerivedData/Build/Products/Release/OpenGraphite.app"

# Developer ID 署名設定
# 公証を行う場合は Developer ID Application 証明書を設定してください。
# 公証をスキップするローカル検証だけなら CODESIGN_IDENTITY="-" を使用できます。
CODESIGN_IDENTITY="Developer ID Application: <YOUR NAME> (<TEAM ID>)"
# OpenGraphite は現時点で配布用 entitlements を持たないため空にします。
CODESIGN_ENTITLEMENTS=""
CODESIGN_OPTIONS="runtime"
CODESIGN_TIMESTAMP=1

# DMG レイアウト設定
DMG_WINDOW_WIDTH=980
DMG_WINDOW_HEIGHT=610
DMG_ICON_SIZE=128
DMG_TEXT_SIZE=16
DMG_APP_ICON_X=164
DMG_APP_ICON_Y=225
DMG_APPLICATIONS_X=784
DMG_APPLICATIONS_Y=225

# 公証 credential は .env 直指定をデフォルト運用とします。
# この 3 つがそろっていれば、Scripts/notarize_local.zsh は NOTARY_PROFILE より優先して使います。
NOTARY_APPLE_ID=""
NOTARY_TEAM_ID=""
NOTARY_APP_PASSWORD=""

# 代替として keychain profile を使う場合だけ設定します。
# profile の作成 / ローテーションは Docs/release/README_local_DMG.md の
# 「ローカルで公証」セクションを参照してください。
NOTARY_PROFILE=""
